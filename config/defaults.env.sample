# Optional installer overrides for fmbcb-rds-multi-scan.
# Copy to a local file and source it before running install.sh, or export only
# the variables you need.

# Install locations
# export FMB_PREFIX=/opt/fmbcb-rds-multi-scan
# export FMB_BIN_DIR=/usr/local/bin
# export FMB_BUILD_ROOT=/usr/local/src/fmbcb-rds-multi-scan-deps

# Native dependency source pins. Leave *_REF blank for upstream default branch.
# export FMB_RX_TOOLS_REPO=https://github.com/xmikos/rx_tools.git
# export FMB_RX_TOOLS_REF=
# export FMB_CSDR_REPO=https://github.com/ha7ilm/csdr.git
# export FMB_CSDR_REF=
# export FMB_REDSEA_REPO=https://github.com/windytan/redsea.git
# export FMB_REDSEA_REF=

# Build toggles
# export FMB_FORCE_BUILD=0
# export FMB_SKIP_APT=0
# export FMB_SKIP_NATIVE_BUILD=0
# export FMB_SKIP_RX_SDR_BUILD=0
# export FMB_SKIP_CSDR_BUILD=0
# export FMB_SKIP_REDSEA_BUILD=0

# Optional: prevent kernel DVB modules from claiming RTL-SDR dongles.
# export FMB_INSTALL_RTL_BLACKLIST=0
